{
    "interface_version": 2,
    "name": "MaaAimisu",
    "description": "基于MaaFramework的あいりすミスティリア日常清理助手",
    "contact": "https://github.com/samipale/MaaAimisu",
    "welcome": "欢迎使用 MaaAimisu!",
    "github": "https://github.com/samipale/MaaAimisu",
    "version": "0.1.0",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb"
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": ".*",
                "screencap": "PrintWindow",
                "mouse": "PostMessageWithCursorPos",
                "keyboard": "PostMessageWithCursorPos"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource/base"
            ]
        },
    ],
    // 可选的 agent 示例
    // "agent": {
    //     "child_exec": "python",
    //     "child_args": [
    //         "./agent/main.py"
    //     ]
    // },
    "task": [
        {
            "name": "普通任务",
            "entry": "MyTask1"
        },
        {
            "name": "选项任务",
            "entry": "MyTask2",
            "option": [
                "任务选项1"
            ]
        },
        {
            "name": "参数任务",
            "entry": "MyTask3",
            "option": [
                "任务选项1"
            ],
            "pipeline_override": {}
        },
        {
            "name": "带Custom的任务",
            "entry": "MyTask4"
        }
    ],
    "option": {
        "任务选项1": {
            "type": "select",
            "cases": [
                {
                    "name": "文本1",
                    "pipeline_override": {
                        "OcrTask": {
                            "text": "文本1"
                        }
                    }
                },
                {
                    "name": "文本2",
                    "pipeline_override": {
                        "OcrTask": {
                            "text": "文本2"
                        }
                    }
                }
            ]
        }
    }
}