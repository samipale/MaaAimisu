{
    "interface_version": 2,
    "name": "MaaAimisu",
    "description": "基于MaaFramework的あいりすミスティリア日常清理助手",
    "contact": "https://github.com/samipale/MaaAimisu",
    "welcome": "欢迎使用 MaaAimisu!",
    "github": "https://github.com/samipale/MaaAimisu",
    "version": "0.0.0",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb"
        },
        {
            "name": "Win端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "あいりすミスティリア|あいミス",
                "screencap": "PrintWindow",
                "mouse": "PostMessageWithCursorPos",
                "keyboard": "PostMessageWithCursorPos"
            },
            "display_raw": true, // 网页端专用设置，如使用的DMM端不是720p，需要把该行删除
            "permission_required": true
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource/base"
            ]
        }
    ],
     "agent": {
         "child_exec": "python",
         "child_args": [
             "./agent/main.py"
         ]
     },
    "task": [],
    "import": [
        "tasks/login.json",
        "tasks/room.json",
        "tasks/skip_event.json",
        "tasks/raid_battle.json",
        "tasks/academy.json",
        "tasks/expedition.json",
        "tasks/mission.json",
        "tasks/gift.json",
        "tasks/stamp_book.json",
        "tasks/quest_battle.json"
    ]
}
