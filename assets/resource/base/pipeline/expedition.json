    "focus": {
      "Node.Recognition.Succeeded": "远征队伍未返回，任务完成"
    }
  },
  "Expedition_CheckExclamation_ClickExpeditionButton": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "!.png",
        "roi": "Expedition_ExpeditionButton",
        "roi_offset": [
          48,
          -49,
          -22,
          16
        ]
      }
    },
    "action": {
      "type": "Click",
      "param": {
        "target": "Expedition_ExpeditionButton"
      }
    },
    "next": [
      "Expedition_Redeploy",
      "Expedition_ViewReport",
      "[JumpBack]Common_UIClose"
    ]
  },
  "Expedition_ViewReport": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "expedition/view_report.png"
      }
    },
    "action": {
      "type": "Click"
    },
    "next": [
      "Expedition_ViewReport_Next",
