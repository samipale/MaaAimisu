{
  "SkipEvent_Entry": {
    "next": [
      "SkipEvent_Entry_AdjustInterface",
      "SkipEvent_DifficultyList",
      "[JumpBack]CommonEvent_GoToDifficultyList"
    ]
  },
  "SkipEvent_Entry_AdjustInterface": {
    "recognition": {
      "type": "And",
      "param": {
        "all_of": [
          "Common_UIClose",
          "CommonBattle_ChooseMultiplyMode"
        ]
      }
    },
    "action": {
      "type": "Click"
    },
    "next": [
      "SkipEvent_DifficultyList"
    ]
  },
  "SkipEvent_DifficultyList": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "quest/battle_start.png"
      }
    },
    "next": [
      "SkipEvent_ChooseClearedQuest",
      "SkipEvent_NoClearedQuest"
    ]
  },
  "SkipEvent_NoClearedQuest": {
    "focus": {
      "Node.Recognition.Succeeded": "没有已通关的任务，无法扫荡，任务中止"
    }
  },
  "SkipEvent_ChooseClearedQuest": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "quest/quest_clear.png",
        "order_by": "Vertical"
      }
    },
    "action": {
      "type": "Click"
    },
    "next": [
      "[JumpBack]CommonBattle_Result_BackToQuestList",
      "SkipEvent_AdjustFailed",
      "[JumpBack]CommonBattle_SkipQuest",
      "SkipEvent_BattleFailed",
      "SkipEvent_DifficultyList"
      ]
  },
  "SkipEvent_BattleFailed": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "quest/failed_to_quest_list.png"
      }
    },
    "action": {
      "type": "Click"
    },
    "focus": {
      "Node.Recognition.Succeeded": "战斗失败，扫荡完成！"
    }
  },
  "SkipEvent_AdjustFailed": {
    "recognition": {
      "type": "And",
      "param": {
        "all_of": [
          "Common_UIClose",
          "CommonBattle_ChooseMultiplyMode"
        ]
      }
    },
    "action": {
      "type": "Click"
    },
    "focus": {
      "Node.Recognition.Succeeded": "扫荡资源不足，扫荡完成！"
    }
  }
}
