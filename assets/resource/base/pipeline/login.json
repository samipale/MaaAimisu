{
  "Login_Entry": {
    "next": [
      "Login_GameStart",
      "[JumpBack]Login_StartApp"
    ]
  },
  "Login_StartApp": {
    "action": {
      "type": "StartApp",
      "param": {
        "package": "com.dmm.games.irismysteria"
      }
    },
    "max_hit": 60,
    "post_wait_freezes": 1000
  },
  "Login_GameStart": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "login/game_start.png"
      }
    },
    "action": {
      "type": "Click"
    },
    "next": [
      "Login_GameStart",
      "[JumpBack]Login_LoginBonus",
      "[JumpBack]Common_UIClose",
      "[JumpBack]Common_Skip",
      "[JumpBack]Common_UINo",
      "[JumpBack]Login_NewCostume",
      "Login_ClickMenu"
    ]
  },
  "Login_LoginBonus": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "login/tap_the_screen.png"
      }
    },
    "action": {
      "type": "Click"
    }
  },
  "Login_NewCostume": {
    "recognition": {
      "type": "OCR",
      "param": {
        "expected": "画面タップで次へ進みます"
      }
    },
    "action": {
      "type": "Click"
    }
  },
  "Login_ClickMenu": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "menu.png"
      }
    },
    "action": {
      "type": "Click"
    },
    "next": [
      "Login_MenuInterface",
      "[JumpBack]Common_UIClose",
      "Login_ClickMenu"
    ]
  },
  "Login_MenuInterface": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "login/menu_interface.png"
      }
    },
    "focus": {
      "Node.Recognition.Succeeded": "登录成功"
    }
  }
}

