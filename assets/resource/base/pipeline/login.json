{
  "Login_Entry": {
    "next": [
      "Login_GameStart",
      "[JumpBack]Login_StartApp"
    ]
  },
  "Login_StartApp": {
    "action": {
      "type": "StartApp",
      "param": {
        "package": "com.dmm.games.irismysteria"
      }
    },
    "max_hit": 60,
    "post_wait_freezes": 1000
  },
  "Login_GameStart": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "login/game_start.png"
      }
    },
    "action": {
      "type": "Click"
    },
    "next": [
      "[JumpBack]Common_UIRetry",
      "[JumpBack]Login_GameStart_Loading",
      "Login_GameStart_Loaded"
    ]
  },
  "Login_GameStart_Loading": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "login/loading.png"
      }
    },
    "post_delay": 3000,
    "max_hit": 100
  },
  "Login_GameStart_Loaded": {
    "next": [
      "[JumpBack]Common_UIClose",
      "[JumpBack]Common_Skip",
      "[JumpBack]Common_UINo",
      "[JumpBack]Common_TapTheScreen",
      "Login_ClickMenu"
    ]
  },
  "Login_ClickMenu": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "menu.png"
      }
    },
    "action": {
      "type": "Click"
    },
    "next": [
      "Login_MenuInterface",
      "[JumpBack]Common_UIClose",
      "[JumpBack]Common_UINo",
      "Login_ClickMenu"
    ]
  },
  "Login_MenuInterface": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "login/menu_interface.png"
      }
    },
    "focus": {
      "Node.Recognition.Succeeded": "登录成功"
    }
  }
}

