  "CommonBattle_RaidQuest_AdjustInterface": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": "raid/multiply_confirm.png"
      }
    },
    "next": [
      "CommonBattle_AdjustRaidSettings"
    ]
  },
  "CommonBattle_AdjustRaidSettings": {
    "action": {
      "type": "Custom",
      "param": {
        "custom_action": "adjust_settings_action"
      }
    },
    "attach": {
      "skip_mode": "raid",
      "max_skip_times": 9
    },
    "next": [
      "CommonBattle_AdjustRaidSettings_StartRaid"
    ],
    "on_error": [
      "CommonBattle_AdjustError"
    ]
  },
