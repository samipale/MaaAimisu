      "param": {
        "template": "raid/damage_point.png"
      }
    },
    "action": {
      "type": "Click",
      "param": {
        "target_offset": [
          0,
          50,
          0,
          0
        ]
      }
    },
    "next": [
      "CommonBattle_RaidQuest_AdjustInterface",
      "CommonBattle_RaidQuest"
